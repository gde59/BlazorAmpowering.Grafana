{
  "name": "bamp-panel",
  "version": "1.0.0",
  "private": true,
  "description": "Panel Grafana de couverture de code en production pour BlazorAmpowering",
  "scripts": {
    "build": "webpack -c webpack.config.ts --env production",
    "dev": "webpack -c webpack.config.ts --watch --env development",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grafana/data": "10.4.0",
    "@grafana/runtime": "10.4.0",
    "@grafana/ui": "10.4.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tslib": "2.6.2"
  },
  "devDependencies": {
    "@swc/core": "1.4.2",
    "@swc/helpers": "0.5.6",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "copy-webpack-plugin": "11.0.0",
    "css-loader": "6.10.0",
    "fork-ts-checker-webpack-plugin": "9.0.2",
    "style-loader": "3.3.4",
    "swc-loader": "0.2.3",
    "ts-node": "10.9.2",
    "typescript": "5.3.3",
    "webpack": "5.90.1",
    "webpack-cli": "5.1.4"
  }
}
